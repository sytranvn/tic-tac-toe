# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# REDIS_URL: The connection string for your Redis instance.
# Example: redis://default:password@host:port
REDIS_URL="redis://localhost:6379"

# DATABASE_URL: The connection string for your Postgres instance.
# Example: postgresql://user:password@localhost:5432/tictactoe
DATABASE_URL="postgresql://user:password@localhost:5432/tictactoe"
